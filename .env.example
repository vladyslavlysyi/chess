# NexusChess Environment Configuration
# Copy this file to .env and fill in production values

# ─── Backend ──────────────────────────────────────────────────────────────────
APP_NAME=NexusChess
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=chess_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=chess_db
DATABASE_URL=postgresql+asyncpg://chess_user:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/chess_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your VPS IP or domain name
ALLOWED_ORIGINS=["http://159.203.185.183","http://localhost:5173"]

# ─── Stockfish ────────────────────────────────────────────────────────────────
STOCKFISH_PATH=/usr/games/stockfish
